import tkinter as tk
import requests
import threading

OLLAMA_URL = "http://localhost:11434/api/chat"
MODEL = "llama3"

messages = [{"role":"system","content":"You are a helpful AI assistant."}]



def add_message(text, role):

    row_bg = "#444654" if role == "assistant" else "#343541"

    row = tk.Frame(chat_container, bg=row_bg)
    row.pack(fill="x")

    inner = tk.Frame(row, bg=row_bg)
    inner.pack(pady=18)

    label = tk.Label(
        inner,
        text=text,
        wraplength=720,
        justify="left",
        font=("Segoe UI",11),
        fg="white",
        bg=row_bg
    )

    label.pack(anchor="w")

    canvas.update_idletasks()
    canvas.yview_moveto(1.0)




def handle_enter(event):
    if not event.state & 0x1:
        send()
        return "break"


def send():

    text = input_box.get("1.0","end").strip()
    if not text:
        return

    input_box.delete("1.0","end")

    add_message(text,"user")

    messages.append({"role":"user","content":text})

    threading.Thread(target=get_ai).start()




def get_ai():

    payload = {
        "model":MODEL,
        "messages":messages,
        "stream":False
    }

    try:
        r = requests.post(OLLAMA_URL,json=payload)
        data = r.json()
        reply = data["message"]["content"]

    except:
        reply = "Error connecting to Ollama."

    messages.append({"role":"assistant","content":reply})

    root.after(0,lambda:add_message(reply,"assistant"))




root = tk.Tk()
root.title("Local ChatGPT")
root.geometry("900x760")
root.configure(bg="#343541")




canvas = tk.Canvas(root,bg="#343541",highlightthickness=0)
scroll = tk.Scrollbar(root,command=canvas.yview)

canvas.configure(yscrollcommand=scroll.set)

scroll.pack(side="right",fill="y")
canvas.pack(side="left",fill="both",expand=True)

chat_container = tk.Frame(canvas,bg="#343541")

canvas.create_window((0,0),window=chat_container,anchor="nw")


def resize(event):
    canvas.configure(scrollregion=canvas.bbox("all"))

chat_container.bind("<Configure>",resize)




input_outer = tk.Frame(root,bg="#343541")
input_outer.pack(fill="x",side="bottom",pady=18)

input_inner = tk.Frame(
    input_outer,
    bg="#40414f",
    padx=12,
    pady=10
)

input_inner.pack(padx=140,fill="x")


input_box = tk.Text(
    input_inner,
    height=2,
    bg="#40414f",
    fg="white",
    insertbackground="white",
    bd=0,
    font=("Segoe UI",11),
    wrap="word"
)

input_box.pack(side="left",fill="both",expand=True)

input_box.bind("<Return>",handle_enter)


send_btn = tk.Button(
    input_inner,
    text="-->",
    command=send,
    bg="#40414f",
    fg="white",
    bd=0,
    font=("Segoe UI",14)
)

send_btn.pack(side="right",padx=6)


root.mainloop()
